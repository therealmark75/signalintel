#!/usr/bin/env bash
# Auth-adjacent pre-commit hook - P23 mechanical enforcement.
# Tracked source: scripts/git-hooks/pre-commit
# Activated copy: .git/hooks/pre-commit (symlink, via scripts/install-hooks.sh)
# See CLAUDE.md and PROJECT_CONTEXT.md P23 for the discipline this enforces.

set -u

# Defensive: git never passes args to pre-commit. install-hooks.sh probes
# the executable bit via --self-test. Any args → harmless no-op + exit 0.
if [[ $# -gt 0 ]]; then
    echo "pre-commit hook is installed"
    exit 0
fi

# --- File-path triggers (locked Phase 1) ---
FILE_PATH_LITERAL=(
    "web/app.py"
    "config/tiers.py"
    "tests/conftest.py"
)
FILE_PATH_GLOBS=(
    "web/auth*.py"
    "web/login*.py"
    "web/session*.py"
)

# Conditional test-file trigger: tests/test_*.py only counts if its diff
# contains session_transaction or sess[ (closes the Phase 1 A.1 gap).
CONDITIONAL_TEST_GLOB="tests/test_*.py"
CONDITIONAL_TEST_PATTERN='session_transaction|sess\['

# Application-code scope for diff-content matching. Excludes scripts/ so
# the hook does not match its own source on installation commits.
APP_PATH_REGEX='^(web/|config/|tests/|signals/|scrapers/|database/|main\.py$)'

# Diff-content patterns (locked Phase 1).
CONTENT_REGEX='current_user\b|@login_required\b|session\[|\.session_transaction\b|\bsess\s*\[|def[[:space:]]+(login|logout|register|authenticate|login_required|current_user)[[:space:]]*\(|def[[:space:]]+(_set_user_tier|_get_user_tier)\b|app\.route\(.*"/(login|logout|register)"'

# --- Collect staged paths ---
STAGED_PATHS=()
while IFS= read -r line; do
    [[ -n "$line" ]] && STAGED_PATHS+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#STAGED_PATHS[@]} -eq 0 ]]; then
    exit 0
fi

# --- Pass 0: dash check (additive, diff-based) ---
# Reject if any ADDED line in the staged diff contains em-dash (U+2014)
# or en-dash (U+2013). Pre-existing dashes are not policed; only newly
# introduced ones block. See CLAUDE.md "Content and writing conventions".
# Detection uses python3 with codepoint escape sequences, never the
# literal glyph, so the hook source stays clean against its own rule.
if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: python3 not on PATH; the dash-check Pass 0 requires it." >&2
    exit 1
fi

DASH_FAIL=0
DASH_REPORT=""

dash_scan_path() {
    local path="$1"
    git diff --cached -U0 -- "$path" 2>/dev/null | python3 -c 'import sys, re
EM = chr(0x2014)
EN = chr(0x2013)
hdr = re.compile(r"^@@ -\d+(?:,\d+)? \+(\d+)(?:,\d+)? @@")
cur = None
for line in sys.stdin:
    line = line.rstrip("\n")
    m = hdr.match(line)
    if m:
        cur = int(m.group(1))
        continue
    if line.startswith("+++ ") or line.startswith("--- "):
        continue
    if line.startswith("+"):
        body = line[1:]
        if EM in body or EN in body:
            tags = []
            if EM in body:
                tags.append("U+2014")
            if EN in body:
                tags.append("U+2013")
            excerpt = body[:120].replace("\t", " ")
            print(str(cur) + "\t" + ",".join(tags) + "\t" + excerpt)
        if cur is not None:
            cur += 1'
}

for p in "${STAGED_PATHS[@]}"; do
    rows=$(dash_scan_path "$p")
    if [[ -n "$rows" ]]; then
        DASH_FAIL=1
        DASH_REPORT+="  $p:"$'\n'
        while IFS=$'\t' read -r ln tags ex; do
            DASH_REPORT+="    line $ln [$tags]: $ex"$'\n'
        done <<< "$rows"
    fi
done

if [[ $DASH_FAIL -eq 1 ]]; then
    echo ""
    echo "============================================"
    echo "DASH-REJECTION: added lines contain em-dash (U+2014) or en-dash (U+2013)"
    echo "============================================"
    printf "%s" "$DASH_REPORT"
    echo "============================================"
    echo "Per CLAUDE.md content-and-writing-conventions (commit 158910b),"
    echo "added lines must contain zero U+2014 and zero U+2013."
    echo "Use commas, periods, semicolons, colons, brackets, or hyphen (U+002D)."
    echo "============================================"
fi

MATCHED=()

path_matches_literal() {
    local path="$1" lit
    for lit in "${FILE_PATH_LITERAL[@]}"; do
        [[ "$path" == "$lit" ]] && return 0
    done
    return 1
}

path_matches_glob() {
    local path="$1" g
    for g in "${FILE_PATH_GLOBS[@]}"; do
        # shellcheck disable=SC2053
        [[ "$path" == $g ]] && return 0
    done
    return 1
}

path_matches_conditional_test() {
    local path="$1"
    # shellcheck disable=SC2053
    [[ "$path" == $CONDITIONAL_TEST_GLOB ]] || return 1
    git diff --cached -U0 -- "$path" 2>/dev/null \
        | grep -E '^\+' | grep -vE '^\+\+\+' \
        | grep -qE "$CONDITIONAL_TEST_PATTERN"
}

# --- Pass 1: file-path triggers ---
for p in "${STAGED_PATHS[@]}"; do
    if path_matches_literal "$p" \
        || path_matches_glob "$p" \
        || path_matches_conditional_test "$p"; then
        MATCHED+=("$p")
    fi
done

# --- Pass 2: diff-content triggers on application Python paths ---
for p in "${STAGED_PATHS[@]}"; do
    skip=0
    for m in "${MATCHED[@]:-}"; do
        [[ "$p" == "$m" ]] && { skip=1; break; }
    done
    [[ $skip -eq 1 ]] && continue
    [[ "$p" =~ $APP_PATH_REGEX ]] || continue
    [[ "$p" == *.py ]] || continue
    if git diff --cached -U0 -- "$p" 2>/dev/null \
        | grep -E '^\+' | grep -vE '^\+\+\+' \
        | grep -qE "$CONTENT_REGEX"; then
        MATCHED+=("$p")
    fi
done

# --- DASH_FAIL is a hard reject; surface P23 too if it matched ---
if [[ $DASH_FAIL -eq 1 ]]; then
    if [[ ${#MATCHED[@]} -gt 0 ]]; then
        echo ""
        echo "(P23 also matched ${#MATCHED[@]} file(s); use --no-verify after fixing dashes)"
    fi
    exit 1
fi

# --- If still empty, non-auth-adjacent commit → silent pass ---
if [[ ${#MATCHED[@]} -eq 0 ]]; then
    exit 0
fi

# --- Header + diff + P23 reminder ---
echo ""
echo "============================================"
echo "AUTH-ADJACENT CHANGE DETECTED"
echo "============================================"
git --no-pager diff --cached -- "${MATCHED[@]}"
echo "============================================"
echo "P23 (PROJECT_CONTEXT.md): auth-adjacent side-effects require"
echo "explicit escalation in audit, not just disclosure."
echo "Matched files:"
for m in "${MATCHED[@]}"; do
    echo "  - $m"
done
echo "============================================"

# --- Open /dev/tty on FD 3 for interactive confirmation ---
if ! { exec 3</dev/tty; } 2>/dev/null; then
    echo "" >&2
    echo "ERROR: No controlling terminal available." >&2
    echo "Auth-adjacent commits MUST be confirmed interactively." >&2
    echo "" >&2
    echo "If you are running in a non-interactive context (CC, CI, scripted commit):" >&2
    echo "  - escalate the change in the commit audit table FIRST (P23)" >&2
    echo "  - then bypass with: git commit --no-verify" >&2
    echo "  - --no-verify leaves an audit signal (no 'pre-commit verified' trace)" >&2
    exit 1
fi

printf "Continue commit? [y/N] " >/dev/tty
read -r REPLY <&3
exec 3<&-

case "${REPLY:-}" in
    y|Y|yes|YES) exit 0 ;;
    *)
        echo "Commit aborted by pre-commit hook." >&2
        exit 1
        ;;
esac
